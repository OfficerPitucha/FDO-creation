@prefix : <https://example.org/fdo/readme#> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix fdoft: <https://w3id.org/fdof/types#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:readmeMetadataIdRecord {
    :readmeMetadata a fdof:FAIRMetadataRecord ;
        fdof:gupri "https://example.org/fdo/readme/readmeMetadata"^^xsd:anyURI ;
        fdof:hasInformationObjectType fdoft:Metadata ;
        fdof:isMaterializedBy :readmeMetadataTrig ;
        fdof:isMetadataOf :readme .
}

