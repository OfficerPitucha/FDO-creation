@prefix : <https://example.org/fdo/readme#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:readmePlainMetadata {
    :readmePlainMetadata fdof:isMetadataOf :readmePlain .

    :readmePlain a dcat:Distribution,
            fdof:FAIRMediaObject ;
        dct:title "Plain Distribution of the Readme"@en ;
        dcat:byteSize "2339"^^xsd:int ;
        dcat:downloadURL <https://example.org/fdo/readme/readme.txt> ;
        dcat:mediaType <https://www.iana.org/assignments/media-types/text/plain> ;
        fdof:gupri "https://example.org/fdo/readme/readmePlain"^^xsd:anyURI ;
        fdof:hasEncodingFormat <https://www.iana.org/assignments/media-types/text/plain> .
}

