@prefix : <https://example.org/fdo/audio#> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix fdoft: <https://w3id.org/fdof/types#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:audioMetadataIdRecord {
    :audioMetadata a fdof:FAIRMetadataRecord ;
        fdof:gupri "https://example.org/fdo/audio/audioMetadata"^^xsd:anyURI ;
        fdof:hasInformationObjectType fdoft:Metadata ;
        fdof:isMaterializedBy :audioMetadataTrig ;
        fdof:isMetadataOf :audio .
}

