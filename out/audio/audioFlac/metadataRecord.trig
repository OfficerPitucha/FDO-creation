@prefix : <https://example.org/fdo/audio#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:audioFlacMetadata {
    :audioFlacMetadata fdof:isMetadataOf :audioFlac .

    :audioFlac a dcat:Distribution,
            fdof:FAIRMediaObject ;
        dct:title "FLAC Distribution of the Audio"@en ;
        dcat:byteSize "108081"^^xsd:int ;
        dcat:downloadURL <https://example.org/fdo/audio/audio.flac> ;
        dcat:mediaType <https://www.iana.org/assignments/media-types/audio/flac> ;
        fdof:gupri "https://example.org/fdo/audio/audioFlac"^^xsd:anyURI ;
        fdof:hasEncodingFormat <https://www.iana.org/assignments/media-types/audio/flac> .
}

