@prefix : <https://example.org/fdo/document#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:documentMetadataTrigMetadata {
    :documentMetadataTrigMetadata fdof:isMetadataOf :documentMetadataTrig .

    :documentMetadataTrig a dcat:Distribution,
            fdof:FAIRMediaObject ;
        dct:title "TriG Distribution of the Metadata Records Related to the Document FAIR Digital Object"@en ;
        dcat:downloadURL <https://example.org/fdo/document/documentMetadata.trig> ;
        dcat:mediaType <https://www.iana.org/assignments/media-types/application/trig> ;
        fdof:gupri "https://example.org/fdo/document/documentMetadataTrig"^^xsd:anyURI ;
        fdof:hasEncodingFormat <https://www.iana.org/assignments/media-types/application/trig> .
}

