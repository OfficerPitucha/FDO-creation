@prefix : <https://example.org/fdo/document#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:documentPdfMetadata {
    :documentPdfMetadata fdof:isMetadataOf :documentPdf .

    :documentPdf a dcat:Distribution,
            fdof:FAIRMediaObject ;
        dct:title "PDF Distribution of the Document"@en ;
        dcat:byteSize "18810"^^xsd:int ;
        dcat:downloadURL <https://example.org/fdo/document/document.pdf> ;
        dcat:mediaType <https://www.iana.org/assignments/media-types/application/pdf> ;
        fdof:gupri "https://example.org/fdo/document/documentPdf"^^xsd:anyURI ;
        fdof:hasEncodingFormat <https://www.iana.org/assignments/media-types/application/pdf> .
}

