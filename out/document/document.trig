@prefix : <https://example.org/fdo/document#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix fdoft: <https://w3id.org/fdof/types#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:documentMetadataTrigMetadata {
    :documentMetadataTrigMetadata fdof:isMetadataOf :documentMetadataTrig .

    :documentMetadataTrig a dcat:Distribution,
            fdof:FAIRMediaObject ;
        dct:title "TriG Distribution of the Metadata Records Related to the Document FAIR Digital Object"@en ;
        dcat:downloadURL <https://example.org/fdo/document/documentMetadata.trig> ;
        dcat:mediaType <https://www.iana.org/assignments/media-types/application/trig> ;
        fdof:gupri "https://example.org/fdo/document/documentMetadataTrig"^^xsd:anyURI ;
        fdof:hasEncodingFormat <https://www.iana.org/assignments/media-types/application/trig> .
}

:documentPdfMetadata {
    :documentPdfMetadata fdof:isMetadataOf :documentPdf .

    :documentPdf a dcat:Distribution,
            fdof:FAIRMediaObject ;
        dct:title "PDF Distribution of the Document"@en ;
        dcat:byteSize "18810"^^xsd:int ;
        dcat:downloadURL <https://example.org/fdo/document/document.pdf> ;
        dcat:mediaType <https://www.iana.org/assignments/media-types/application/pdf> ;
        fdof:gupri "https://example.org/fdo/document/documentPdf"^^xsd:anyURI ;
        fdof:hasEncodingFormat <https://www.iana.org/assignments/media-types/application/pdf> .
}

:skeleton {
    :documentMetadata a fdof:FAIRMetadataRecord ;
        fdof:gupri "https://example.org/fdo/document/documentMetadata"^^xsd:anyURI ;
        fdof:hasInformationObjectType fdoft:Metadata ;
        fdof:isMaterializedBy :documentMetadataTrig ;
        fdof:isMetadataOf :document .

    :document a fdof:FAIRInformationObject ;
        fdof:gupri "https://example.org/fdo/document/document"^^xsd:anyURI ;
        fdof:hasInformationObjectType fdoft:Article ;
        fdof:isMaterializedBy :documentPdf .

    :documentMetadataTrigMetadata a fdof:FAIRMetadataRecord ;
        fdof:gupri "https://example.org/fdo/document/documentMetadataTrigMetadata"^^xsd:anyURI ;
        fdof:hasInformationObjectType fdoft:MediaObjectMetadataRecord ;
        fdof:isMaterializedBy :documentMetadataTrig ;
        fdof:isMetadataOf :documentMetadataTrig .

    :documentPdfMetadata a fdof:FAIRMetadataRecord ;
        fdof:gupri "https://example.org/fdo/document/documentPdfMetadata"^^xsd:anyURI ;
        fdof:hasInformationObjectType fdoft:MediaObjectMetadataRecord ;
        fdof:isMaterializedBy :documentMetadataTrig ;
        fdof:isMetadataOf :documentPdf .

    :documentPdf a fdof:FAIRMediaObject ;
        fdof:gupri "https://example.org/fdo/document/documentPdf"^^xsd:anyURI ;
        fdof:hasEncodingFormat <https://www.iana.org/assignments/media-types/application/pdf> .

    :documentMetadataTrig a fdof:FAIRMediaObject ;
        fdof:gupri "https://example.org/fdo/document/documentMetadataTrig"^^xsd:anyURI ;
        fdof:hasEncodingFormat <https://www.iana.org/assignments/media-types/application/trig> .
}

:documentMetadata {
    :documentMetadata fdof:isMetadataOf :document .

    :document a dcat:Dataset,
            fdof:FAIRInformationObject ;
        dct:identifier "https://example.org/fdo/document/document" ;
        dct:issued "2026-06-17"^^xsd:date ;
        dct:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
        dct:title "Document" ;
        dcat:distribution :documentPdf ;
        fdof:gupri "https://example.org/fdo/document/document"^^xsd:anyURI ;
        fdof:hasInformationObjectType fdoft:Article ;
        fdof:isMaterializedBy :documentPdf .
}

