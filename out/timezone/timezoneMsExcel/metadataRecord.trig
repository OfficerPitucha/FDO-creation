@prefix : <https://example.org/fdo/timezone#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:timezoneMsExcelMetadata {
    :timezoneMsExcelMetadata fdof:isMetadataOf :timezoneMsExcel .

    :timezoneMsExcel a dcat:Distribution,
            fdof:FAIRMediaObject ;
        dct:title "MsExcel Distribution of the Timezone"@en ;
        dcat:byteSize "16249"^^xsd:int ;
        dcat:downloadURL <https://example.org/fdo/timezone/timezone.csv> ;
        dcat:mediaType <https://www.iana.org/assignments/media-types/application/vnd.ms-excel> ;
        fdof:gupri "https://example.org/fdo/timezone/timezoneMsExcel"^^xsd:anyURI ;
        fdof:hasEncodingFormat <https://www.iana.org/assignments/media-types/application/vnd.ms-excel> .
}

