@prefix : <https://example.org/fdo/image#> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix fdoft: <https://w3id.org/fdof/types#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:imageMetadataIdRecord {
    :imageMetadata a fdof:FAIRMetadataRecord ;
        fdof:gupri "https://example.org/fdo/image/imageMetadata"^^xsd:anyURI ;
        fdof:hasInformationObjectType fdoft:Metadata ;
        fdof:isMaterializedBy :imageMetadataTrig ;
        fdof:isMetadataOf :image .
}

