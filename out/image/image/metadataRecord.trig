@prefix : <https://example.org/fdo/image#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix fdof: <https://w3id.org/fdof/ontology#> .
@prefix fdoft: <https://w3id.org/fdof/types#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:imageMetadata {
    :imageMetadata fdof:isMetadataOf :image .

    :image a dcat:Dataset,
            fdof:FAIRInformationObject ;
        dct:description "random image" ;
        dct:identifier "https://example.org/fdo/image/image" ;
        dct:issued "2026-06-18"^^xsd:date ;
        dct:license <https://creativecommons.org/publicdomain/mark/1.0/> ;
        dct:title "Image" ;
        dcat:distribution :imageJpeg ;
        fdof:gupri "https://example.org/fdo/image/image"^^xsd:anyURI ;
        fdof:hasInformationObjectType fdoft:Photograph ;
        fdof:isMaterializedBy :imageJpeg .
}

